# ============================================
# bytropix .gitignore — binary artifacts & runtime data
# ============================================

# ---- Compiled binaries (root) ----
# Generated by 'make' — never commit ELF files
# NOTE: only extensionless files at root level, not .c/.h source files
/gen_text
/gen_text_gpu
/ref_dumper
/infer_text
/infer_vision_text
/infer_vision_text_gpu
/gen_ref_logits
/gen_text_mtp
/ref_dumper_mtp
/ref_forward
/ref_get_embd
/get_ref_hidden
/profile_ssm_full
/train_integrated
/train_real_dbg
/train_stub
/compare_weights
/gqa_layer_check
/inspect_model_types

# Root ELF files — leading / ensures only root, no ext ensures no source
/test_*
/check_*
/dump_*
/debug_*
/verify_*
/scan_*
/train_*
/compare_*
/diff_*
/run_*
/ssm_*
/dbg_*
/dequant_*
/bench_thread*

# Specific root binaries (extensionless, root only)
/stage_debug
/list_tensors
/single_block_test
/tok_check
/q5k_check
/extract_and_map
/td
/td2

# ---- Object files & build artifacts ----
*.o
*.obj
*.a
*.so
*.dylib
*.d
*.olean
*.lake

# ---- Binary data files (runtime, not source) ----
*.bin
*.bin.*
*.gz
*.pkl
*.zip
*.tar
*.tar.gz
*.tgz
*.xz
*.bz2

# ---- Research papers (PDFs not source) ----
*.pdf

# ---- Images & media ----
*.png
*.jpg
*.jpeg
*.gif
*.svgz
*.ico
*.mp4
*.webm
*.ogg
*.wav
*.mp3

# ---- Python artifacts ----
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
*.whl

# ---- Build directories ----
build/

# ---- WSL / Windows ----
*.exe
*.dll

# ---- Debug logs ----
debug.log
temp_forward_full_block.txt

# ---- Make fragments (generated) ----
*.mk
